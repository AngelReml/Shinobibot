{
  "name": "shinobibot",
  "version": "1.0.0",
  "description": "Shinobi — autonomous Windows-native agent. Public v1.0.0 release.",
  "homepage": "https://zapweave.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngelReml/Shinobibot.git"
  },
  "license": "ISC",
  "main": "dist/scripts/shinobi.js",
  "type": "module",
  "bin": {
    "shinobi": "dist/scripts/shinobi.js"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/better-sqlite3/prebuilds/**/*"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "build"
  },
  "scripts": {
    "start": "tsx scripts/shinobi.ts",
    "dev": "tsx scripts/shinobi_web.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "tui": "tsx scripts/shinobi-tui.tsx",
    "bench": "tsx scripts/benchmarks/run.ts",
    "bench:compare": "tsx scripts/bench.ts",
    "bench:agentic": "tsx scripts/bench_s_agentic.ts",
    "build:exe": "tsx scripts/build_exe.ts"
  },
  "keywords": [],
  "author": "AngelReml",
  "dependencies": {
    "@e2b/sdk": "^0.8.6",
    "@huggingface/transformers": "^4.2.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "docx": "^9.6.1",
    "dotenv": "^16.3.0",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "grammy": "^1.42.0",
    "isolated-vm": "^6.1.2",
    "openai": "^6.34.0",
    "playwright": "^1.59.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "ink": "^7.0.3",
    "promptfoo": "^0.121.11",
    "react": "^19.2.6",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
