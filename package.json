{
  "name": "shinobibot",
  "version": "1.0.0",
  "description": "Shinobi — autonomous Windows-native agent. Public v1.0.0 release.",
  "homepage": "https://zapweave.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngelReml/Shinobibot.git"
  },
  "license": "ISC",
  "main": "dist/scripts/shinobi.js",
  "type": "module",
  "bin": {
    "shinobi": "dist/scripts/shinobi.js"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/better-sqlite3/prebuilds/**/*",
      "node_modules/sqlite-vec/**/*"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "build"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "AngelReml",
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.3.0",
    "express": "^4.22.1",
    "openai": "^6.34.0",
    "playwright": "^1.59.1",
    "sqlite-vec": "^0.1.9",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
