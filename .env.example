# Configuración de Modelos e IA
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# Modo y Configuración del Compactor
# Modos válidos: heuristic | llm | auto
SHINOBI_COMPACTOR_MODE=heuristic
SHINOBI_COMPACTOR_BUDGET_TOKENS=32000
SHINOBI_COMPACTOR_THRESHOLD_RATIO=0.75
SHINOBI_COMPACTOR_FLOOR_RATIO=0.40

# Sistema de Aprobación de Herramientas
# Modos válidos: smart | on | off
SHINOBI_APPROVAL_MODE=smart
SHINOBI_APPROVAL_TIMEOUT_MS=120000

# Integración Sandbox E2B Cloud
E2B_API_KEY=

# Canales de Comunicación (Opcional)
# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (IMAP/SMTP)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
