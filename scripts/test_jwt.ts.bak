import { ShinobiOrchestrator } from '../src/coordinator/ShinobiOrchestrator.ts';
import { OpenGravityBridge } from '../src/bridge/opengravity.ts';
import dotenv from 'dotenv';

dotenv.config();

async function runTest() {
  const ShinobiOrchestrator = new ShinobiOrchestrator();
  const bridge = new OpenGravityBridge();

  const task = "Write a high-performance JWT validator script in Node.js. It should include token decoding, signature verification using RS256, and expiration checks. No fluff, just the logic.";
  
  console.log("--- Shinobibot Task Start ---");
  const code = await ShinobiOrchestrator.executeTask(task, { provider: 'groq', model: 'llama-3.3-70b-versatile' });
  
  console.log("\n[Shinobibot] Generated Code:\n", code);

  console.log("\n--- OpenGravity V3 Audit ---");
  const auditResult = await bridge.audit(code, 'jwt_validator.ts');
  
  console.log("\n[Audit Result]", auditResult);
  console.log("Check the report here:", auditResult.report);
}

runTest().catch(console.error);
